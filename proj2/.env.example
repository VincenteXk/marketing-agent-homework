# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 通用文生图（视觉智能，异步提交+轮询）
TEXT2IMAGE_ACCESS_KEY_ID=
TEXT2IMAGE_SECRET_ACCESS_KEY=
# 可选：生图面积，默认 2048*2048（2K）
TEXT2IMAGE_SIZE=4194304
# 可选：轮询间隔（秒）与最大轮询次数
# TEXT2IMAGE_POLL_INTERVAL_SEC=3
# TEXT2IMAGE_POLL_MAX_ATTEMPTS=80

# 主视觉验收（字节方舟视觉模型，与 DeepSpeak server/routes/vlmProxy 同源）
VLM_ARK_API_KEY=
# VLM_MODEL=doubao-seed-1-6-flash-250828